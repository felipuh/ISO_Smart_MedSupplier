# ===============================
# ISO Smart Backend Environment
# ===============================

# Core Django
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-this-dev-secret-key-before-deploy
SMART3AI_SSO_JWT_SECRET=change-this-shared-sso-jwt-secret
SMART3AI_SSO_ISSUER=https://sso.smart3ai.local
SMART3AI_SSO_AUDIENCE=smart3ai-portfolio
ALLOWED_HOSTS=localhost,127.0.0.1,192.168.100.100,isosmart.local

# For production:
# ENVIRONMENT=production
# DEBUG=False
# SECRET_KEY=<set-a-secure-random-value>

# Primary database
DB_NAME=isosmart_main
DB_USER=isosmart
DB_PASSWORD=isosmart123
DB_HOST=127.0.0.1
DB_PORT=5432

# AI database (optional override)
AI_DB_NAME=isosmart_ai
AI_DB_USER=isosmart
AI_DB_PASSWORD=isosmart123
AI_DB_HOST=127.0.0.1
AI_DB_PORT=5432

# Audit database (optional override)
AUDIT_DB_NAME=isosmart_audit
AUDIT_DB_USER=isosmart
AUDIT_DB_PASSWORD=isosmart123
AUDIT_DB_HOST=127.0.0.1
AUDIT_DB_PORT=5432

# AdminApps integration
ADMIN_APPS_BASE_URL=http://127.0.0.1:8000/api/integration
ADMIN_APPS_API_KEY=replace_with_adminapps_api_key
ADMIN_APPS_TIMEOUT=10
ADMIN_APPS_CACHE_TTL=300
ADMIN_APPS_SYNC_USERS=True

# Browser/API security
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://isosmart.local
CSRF_TRUSTED_ORIGINS=http://192.168.100.100:3001,http://192.168.100.100,http://localhost:3001
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=300/minute

# AI Assistant provider (OpenAI-compatible)
AI_ASSISTANT_API_URL=https://api.openai.com/v1/chat/completions
AI_ASSISTANT_API_KEY=your_provider_api_key_here
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_ASSISTANT_SUPPORTED_STANDARDS=ISO 9001, ISO 14001, ISO 45001, ISO 27001, ISO 42001
AI_ASSISTANT_SYSTEM_PROMPT=Eres el asistente virtual de ISO Smart. Responde en español de forma breve, precisa y accionable. Tu foco principal es orientar sobre sistemas de gestion, clausulas, evidencias, registros, riesgos, auditorias, no conformidades, acciones correctivas e implementacion por etapas. Normas prioritarias soportadas: ISO 9001, ISO 14001, ISO 45001, ISO 27001, ISO 42001. Si la consulta menciona una norma, responde alineado a esa norma. Si no la menciona, prioriza ISO 9001 como base y aclara cuando una recomendacion depende de la norma aplicable. No inventes requisitos normativos. Si falta contexto, indicalo y pide la informacion minima necesaria. Siempre sugiere el siguiente paso practico dentro del modulo actual cuando aplique.
