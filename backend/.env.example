# ISO Smart MedSupplier backend environment example
#
# Copy to backend/.env for local development. Do not commit real secrets.

# Runtime
ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-this-dev-secret-key-before-deploy
ALLOWED_HOSTS=localhost,127.0.0.1,medsupplier.local,medsupplier.smart3ai.local

# Smart3AI/AdminApps identity
SMART3AI_SSO_JWT_SECRET=change-this-shared-sso-jwt-secret
SMART3AI_SSO_ISSUER=https://sso.smart3ai.local
SMART3AI_SSO_AUDIENCE=smart3ai-portfolio

# AdminApps integration
ADMIN_APPS_BASE_URL=http://127.0.0.1:8000/api/integration
ADMIN_APPS_API_KEY=replace_with_adminapps_internal_api_key
ADMIN_APPS_TIMEOUT=10
ADMIN_APPS_CACHE_TTL=300
ADMIN_APPS_SYNC_USERS=True
ADMIN_APPS_REQUIRE_IDENTITY_SOURCE=True
ADMIN_APPS_ALLOW_LOCAL_FALLBACK=False

# MedSupplier packaging
# Allowed values currently used by code: standalone, integrated.
MEDSUPPLIER_PRODUCT_MODE=standalone

# Owner/demo organization controls
OWNER_ORGANIZATION_ONLY_ACCESS=True
OWNER_ORGANIZATION_SLUG=smart3ai
OWNER_ORGANIZATION_NAME=Smart3AI
OWNER_ORGANIZATION_EXTERNAL_ID=
OWNER_ORGANIZATION_BILLING_EXEMPT=True
ALLOW_LOCAL_AUTH_BYPASS_FOR_TESTS=False

# Primary database
DB_NAME=medsupplier_main
DB_USER=medsupplier
DB_PASSWORD=replace_with_local_password
DB_HOST=127.0.0.1
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Optional AI database
AI_DB_NAME=medsupplier_ai
AI_DB_USER=medsupplier
AI_DB_PASSWORD=replace_with_local_password
AI_DB_HOST=127.0.0.1
AI_DB_PORT=5432

# Optional audit database
AUDIT_DB_NAME=medsupplier_audit
AUDIT_DB_USER=medsupplier
AUDIT_DB_PASSWORD=replace_with_local_password
AUDIT_DB_HOST=127.0.0.1
AUDIT_DB_PORT=5432

# Browser/API security for local development
CORS_ALLOWED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://medsupplier.local:3001
CSRF_TRUSTED_ORIGINS=http://localhost:3001,http://127.0.0.1:3001,http://medsupplier.local:3001
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
SECURE_SSL_REDIRECT=False
SECURE_HSTS_SECONDS=0
SECURE_HSTS_INCLUDE_SUBDOMAINS=False
SECURE_HSTS_PRELOAD=False
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=300/minute

# Email and user flows
DEFAULT_FROM_EMAIL=noreply@medsupplier.local
FRONTEND_BASE_URL=http://localhost:3001
PASSWORD_RESET_TOKEN_EXPIRY_MINUTES=30
PASSWORD_RESET_WINDOW_MINUTES=60
PASSWORD_RESET_MAX_REQUESTS_PER_HOUR=5
PASSWORD_HISTORY_COUNT=5
TEMP_PASSWORD_MAX_AGE_DAYS=7
TEMP_PASSWORD_WARNING_DAYS=2
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# Logs
ISOSMART_LOG_DIR=/tmp/medsupplier-logs

# Production-like example overrides
#
# ENVIRONMENT=production
# DEBUG=False
# SECRET_KEY=replace_with_long_random_secret_from_secret_manager
# ALLOWED_HOSTS=medsupplier.smart3ai.local,medsupplier.isosmart.local
# CORS_ALLOWED_ORIGINS=https://medsupplier.smart3ai.local
# CSRF_TRUSTED_ORIGINS=https://medsupplier.smart3ai.local
# SESSION_COOKIE_SECURE=True
# CSRF_COOKIE_SECURE=True
# SECURE_SSL_REDIRECT=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=False
# ADMIN_APPS_ALLOW_LOCAL_FALLBACK=False

# AI assistant provider, optional for local validation
AI_ASSISTANT_API_URL=https://api.openai.com/v1/chat/completions
AI_ASSISTANT_API_KEY=
AI_ASSISTANT_MODEL=gpt-4o-mini
AI_ASSISTANT_SUPPORTED_STANDARDS=ISO 9001, ISO 13485, ISO 14971
AI_ASSISTANT_SYSTEM_PROMPT=You are the MedSupplier assistant. Provide concise, evidence-ready guidance for supplier-customer quality, documentation, CAPA, logistics, and audit preparation. Do not claim formal regulatory compliance without validated evidence.
