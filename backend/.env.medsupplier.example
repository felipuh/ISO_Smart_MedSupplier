# ===============================
# ISO Smart MedSupplier Environment
# ===============================

# Product mode:
# standalone = sold/operated separately from Iso Smart, but still governed by AdminApps
# integrated = sold together with Iso Smart and shares QMS evidence flows
MEDSUPPLIER_PRODUCT_MODE=integrated

ENVIRONMENT=development
DEBUG=True
SECRET_KEY=change-this-dev-secret-key-before-deploy
ALLOWED_HOSTS=localhost,127.0.0.1,medsupplier.isosmart.local,medsupplier.smart3ai.local

# Shared SSO uses AdminApps as the identity/business authority.
SMART3AI_SSO_JWT_SECRET=change-this-shared-sso-jwt-secret
SMART3AI_SSO_ISSUER=https://sso.smart3ai.local

# Standalone database recommendation.
DB_NAME=medsupplier_main
DB_USER=medsupplier
DB_PASSWORD=change-this-password
DB_HOST=127.0.0.1
DB_PORT=5432

# Optional separated stores.
AI_DB_NAME=medsupplier_ai
AI_DB_USER=medsupplier
AI_DB_PASSWORD=change-this-password
AI_DB_HOST=127.0.0.1
AI_DB_PORT=5432
AUDIT_DB_NAME=medsupplier_audit
AUDIT_DB_USER=medsupplier
AUDIT_DB_PASSWORD=change-this-password
AUDIT_DB_HOST=127.0.0.1
AUDIT_DB_PORT=5432

# AdminApps is the business brain for every Smart3AI product:
# organizations, users, roles, subscriptions and module entitlements are created there.
ADMIN_APPS_BASE_URL=http://127.0.0.1:8000/api/integration
ADMIN_APPS_API_KEY=replace_with_adminapps_api_key
ADMIN_APPS_TIMEOUT=10
ADMIN_APPS_CACHE_TTL=300
ADMIN_APPS_SYNC_USERS=True
ADMIN_APPS_REQUIRE_IDENTITY_SOURCE=True

CORS_ALLOWED_ORIGINS=http://medsupplier.isosmart.local,http://medsupplier.smart3ai.local
CSRF_TRUSTED_ORIGINS=http://medsupplier.isosmart.local,http://medsupplier.smart3ai.local
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
THROTTLE_ANON_RATE=60/minute
THROTTLE_USER_RATE=300/minute
